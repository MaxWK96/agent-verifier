verdict-registry-address: "0xff687eC2191d3EE6DDF28Ee806B45c8D837C128E"

staging-settings:
  rpcs:
    - chain-name: ethereum-testnet-sepolia
      url: https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

production-settings:
  rpcs:
